{
  // MCP Servers สำหรับ company AI bot
  "mcp": {
    // Odoo Cloud — stdio transport (installed inside opencode container)
    "odoo": {
      "type": "local",
      "command": "python",
      "args": ["-m", "odoo_mcp.server"],
      "env": {
        "ODOO_URL": "${ODOO_URL}",
        "ODOO_DB": "${ODOO_DB}",
        "ODOO_USERNAME": "${ODOO_USERNAME}",
        "ODOO_PASSWORD": "${ODOO_PASSWORD}"
      }
    },
    // Company RAG — HTTP transport (separate container)
    "company-rag": {
      "type": "remote",
      "url": "http://rag-mcp:5000/mcp"
    }
  }
}
