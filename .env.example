# ============================================================
# LINE OA
# ============================================================
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_OA_URL=

# ============================================================
# AI Provider
# ============================================================
ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# GOOGLE_API_KEY=
# QWEN_API_KEY=
# GROQ_API_KEY=

# ============================================================
# OpenCode
# ============================================================
OPENCODE_PASSWORD=changeme
# GITHUB_TOKEN=          # optional — ถ้าต้องการให้ bot push/pull GitHub ใน workspace

# ============================================================
# Odoo Cloud (production)
# ============================================================
ODOO_URL=https://your-company.odoo.com
ODOO_DB=your_database
ODOO_USERNAME=admin
ODOO_PASSWORD=your_api_key

# ============================================================
# Local Odoo (สำหรับทดสอบ)
# ใช้ร่วมกับ: docker compose --profile local-odoo up -d
# Login ครั้งแรก: http://localhost:8069  (สร้าง DB ชื่อ "odoo")
# แล้วเปลี่ยน ODOO_URL เป็น http://odoo-local:8069
# ============================================================
# ODOO_URL=http://odoo-local:8069
# ODOO_DB=odoo
# ODOO_USERNAME=admin
# ODOO_PASSWORD=admin
# ODOO_LOCAL_DB_PASSWORD=odoo

# ============================================================
# Cloudflare Tunnel
# ============================================================
CLOUDFLARE_TUNNEL_TOKEN=

# ============================================================
# RAG Ingestion
# ============================================================
# INGEST_SOURCE=markdown        ← default (markdown เท่านั้น)
# INGEST_SOURCE=all             ← markdown + Odoo sync (ต้องการ Odoo credentials)
# ODOO_SYNC_MODELS=product.template,res.partner
